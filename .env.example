# =============================================================================
# RANKING PONG — Variáveis de Ambiente
#
# Copie este arquivo para .env.local (desenvolvimento) ou configure as
# variáveis diretamente no painel do seu provedor de hospedagem (produção).
#
# Variáveis prefixadas com NEXT_PUBLIC_ são expostas ao browser.
# As demais são exclusivamente server-side e NUNCA devem aparecer no cliente.
#
# Para testes automatizados, copie também para .env.test e ajuste os valores
# para o ambiente de homologação (ver seção "Testes" abaixo).
# =============================================================================


# -----------------------------------------------------------------------------
# SUPABASE
# Painel: https://supabase.com/dashboard → seu projeto → Project Settings → API
# -----------------------------------------------------------------------------

# URL pública do projeto (exposta ao browser — usada pelo cliente JS)
NEXT_PUBLIC_SUPABASE_URL=https://<seu-projeto>.supabase.co

# Chave anônima / publishable — permissões limitadas pelas políticas de RLS
# Também aceita o nome alternativo NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon_key>

# Chave de serviço (service_role) — bypassa RLS, usar APENAS no servidor
# NUNCA expor ao browser ou commitar no repositório
SUPABASE_SERVICE_ROLE_KEY=<service_role_key>


# -----------------------------------------------------------------------------
# WEB PUSH / VAPID
# Gere um par de chaves com: npx web-push generate-vapid-keys
# Documentação: https://developers.google.com/web/fundamentals/push-notifications
# -----------------------------------------------------------------------------

# Chave pública VAPID (exposta ao browser — usada para registrar o service worker)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=<vapid_public_key>

# Chave privada VAPID (server-side apenas — assina as notificações enviadas)
VAPID_PRIVATE_KEY=<vapid_private_key>

# Identificação do remetente: e-mail (mailto:) ou URL do domínio (https://)
VAPID_SUBJECT=mailto:seu@email.com


# -----------------------------------------------------------------------------
# APLICAÇÃO
# -----------------------------------------------------------------------------

# Fuso horário usado para calcular datas de partidas e limites diários
# Valores aceitos: qualquer identificador IANA (ex.: America/Sao_Paulo, UTC)
# Padrão interno: America/Sao_Paulo
APP_TIMEZONE=America/Sao_Paulo


# -----------------------------------------------------------------------------
# BRANDING DO PRODUTO (white label)
#
# Cada deploy define sua identidade visual via estas variáveis. Se omitidas,
# o app mostra a identidade neutra "PRODUTO_NOME" com paleta azul. Veja
# docs/BRANDING_PRODUTO.md e public/branding/README.md para detalhes.
#
# Exemplos de configuração:
#   - Vercel PROD (preserva Smash Pong): use os valores comentados abaixo
#   - Coolify HML (cara do produto): deixe vazio ou use defaults novos
#   - Futuros clientes: cada um com seu conjunto
# -----------------------------------------------------------------------------

# Identidade textual
NEXT_PUBLIC_PRODUCT_NAME=PRODUTO_NOME
NEXT_PUBLIC_PRODUCT_SHORT_NAME=PRODUTO_NOME
NEXT_PUBLIC_PRODUCT_OWNER=PRODUTO_OWNER
NEXT_PUBLIC_PRODUCT_DESCRIPTION=Sistema de ranking esportivo com pontuação e notícias em tempo real.
NEXT_PUBLIC_SPORT_LABEL=esporte
NEXT_PUBLIC_SPORT_EMOJI=🏆

# Paleta visual (CSS) — injetada como CSS vars no <head> em runtime
NEXT_PUBLIC_PRIMARY_COLOR=#2563eb
NEXT_PUBLIC_PRIMARY_DARK=#60a5fa
NEXT_PUBLIC_BACKGROUND_COLOR=#f8fafc
NEXT_PUBLIC_BACKGROUND_DARK=#0f172a
NEXT_PUBLIC_THEME_COLOR_PWA=#2563eb

# Assets (logo + ícones PWA) — paths relativos a /public/
# Crie uma subpasta em public/branding/<slug>/ com os 6 arquivos (ver README)
NEXT_PUBLIC_LOGO_PATH=/branding/template/logo.png
NEXT_PUBLIC_ICON_192_PATH=/branding/template/icon-192.png
NEXT_PUBLIC_ICON_512_PATH=/branding/template/icon-512.png
NEXT_PUBLIC_ICON_MASKABLE_PATH=/branding/template/icon-512-maskable.png
NEXT_PUBLIC_BADGE_72_PATH=/branding/template/badge-72.png
NEXT_PUBLIC_APPLE_TOUCH_PATH=/branding/template/apple-touch-icon.png
NEXT_PUBLIC_FAVICON_PATH=/branding/template/favicon.ico

# Prefixo usado em localStorage/sessionStorage/IndexedDB/cache buster
# Trocar quebra caches existentes (toasts pendentes, queries persistidas).
# Em Vercel PROD use "smash-pong" para preservar caches dos usuários atuais.
NEXT_PUBLIC_STORAGE_PREFIX=ranking-app

# -----------------------------------------------------------------------------
# Configuração de PROD (Vercel) — preserva identidade Smash Pong
# Descomente e configure no painel Vercel se quiser usar como referência:
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_PRODUCT_NAME=Smash Pong App
# NEXT_PUBLIC_PRODUCT_SHORT_NAME=Smash Pong App
# NEXT_PUBLIC_PRODUCT_OWNER=ALSS Tech
# NEXT_PUBLIC_PRODUCT_DESCRIPTION=Aplicativo mobile-first de ranking interno de tênis de mesa com pontuação e notícias em tempo real.
# NEXT_PUBLIC_SPORT_LABEL=tênis de mesa
# NEXT_PUBLIC_SPORT_EMOJI=🏓
# NEXT_PUBLIC_PRIMARY_COLOR=#a421d2
# NEXT_PUBLIC_PRIMARY_DARK=#d35eff
# NEXT_PUBLIC_BACKGROUND_COLOR=#f8f1ff
# NEXT_PUBLIC_BACKGROUND_DARK=#2b003c
# NEXT_PUBLIC_THEME_COLOR_PWA=#a421d2
# NEXT_PUBLIC_LOGO_PATH=/branding/smashpong/logo.png
# NEXT_PUBLIC_ICON_192_PATH=/branding/smashpong/icon-192.png
# NEXT_PUBLIC_ICON_512_PATH=/branding/smashpong/icon-512.png
# NEXT_PUBLIC_ICON_MASKABLE_PATH=/branding/smashpong/icon-512-maskable.png
# NEXT_PUBLIC_BADGE_72_PATH=/branding/smashpong/badge-72.png
# NEXT_PUBLIC_APPLE_TOUCH_PATH=/branding/smashpong/apple-touch-icon.png
# NEXT_PUBLIC_FAVICON_PATH=/branding/smashpong/favicon.ico
# NEXT_PUBLIC_STORAGE_PREFIX=smash-pong


# =============================================================================
# TESTES AUTOMATIZADOS (.env.test)
# As variáveis abaixo são usadas exclusivamente pela suíte de testes Vitest +
# Playwright e devem apontar para o ambiente de homologação (HML), nunca para
# produção.  Copie este bloco para .env.test e preencha com as credenciais HML.
# =============================================================================

# URL base da aplicação — usada pelo Playwright para navegar nas páginas E2E
APP_BASE_URL=https://hml.seudominio.com.br

# Prefixo de e-mail dos usuários criados pelos testes (ex.: qa-rankingpong-)
# O cleanup global exclui qualquer usuário cujo e-mail comece com este prefixo
TEST_USER_PREFIX=qa-rankingpong

# Senha atribuída a todos os usuários de teste criados em runtime
# Use uma senha forte — o banco HML é compartilhado
TEST_USER_PASSWORD=Qa!Rank1ng#2026
