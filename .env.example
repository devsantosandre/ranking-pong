# =============================================================================
# RANKING PONG — Variáveis de Ambiente
#
# Copie este arquivo para .env.local (desenvolvimento) ou configure as
# variáveis diretamente no painel do seu provedor de hospedagem (produção).
#
# Variáveis prefixadas com NEXT_PUBLIC_ são expostas ao browser.
# As demais são exclusivamente server-side e NUNCA devem aparecer no cliente.
#
# Para testes automatizados, copie também para .env.test e ajuste os valores
# para o ambiente de homologação (ver seção "Testes" abaixo).
# =============================================================================


# -----------------------------------------------------------------------------
# SUPABASE
# Painel: https://supabase.com/dashboard → seu projeto → Project Settings → API
# -----------------------------------------------------------------------------

# URL pública do projeto (exposta ao browser — usada pelo cliente JS)
NEXT_PUBLIC_SUPABASE_URL=https://<seu-projeto>.supabase.co

# Chave anônima / publishable — permissões limitadas pelas políticas de RLS
# Também aceita o nome alternativo NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon_key>

# Chave de serviço (service_role) — bypassa RLS, usar APENAS no servidor
# NUNCA expor ao browser ou commitar no repositório
SUPABASE_SERVICE_ROLE_KEY=<service_role_key>


# -----------------------------------------------------------------------------
# WEB PUSH / VAPID
# Gere um par de chaves com: npx web-push generate-vapid-keys
# Documentação: https://developers.google.com/web/fundamentals/push-notifications
# -----------------------------------------------------------------------------

# Chave pública VAPID (exposta ao browser — usada para registrar o service worker)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=<vapid_public_key>

# Chave privada VAPID (server-side apenas — assina as notificações enviadas)
VAPID_PRIVATE_KEY=<vapid_private_key>

# Identificação do remetente: e-mail (mailto:) ou URL do domínio (https://)
VAPID_SUBJECT=mailto:seu@email.com


# -----------------------------------------------------------------------------
# APLICAÇÃO
# -----------------------------------------------------------------------------

# Fuso horário usado para calcular datas de partidas e limites diários
# Valores aceitos: qualquer identificador IANA (ex.: America/Sao_Paulo, UTC)
# Padrão interno: America/Sao_Paulo
APP_TIMEZONE=America/Sao_Paulo


# =============================================================================
# TESTES AUTOMATIZADOS (.env.test)
# As variáveis abaixo são usadas exclusivamente pela suíte de testes Vitest +
# Playwright e devem apontar para o ambiente de homologação (HML), nunca para
# produção.  Copie este bloco para .env.test e preencha com as credenciais HML.
# =============================================================================

# URL base da aplicação — usada pelo Playwright para navegar nas páginas E2E
APP_BASE_URL=https://hml.seudominio.com.br

# Prefixo de e-mail dos usuários criados pelos testes (ex.: qa-rankingpong-)
# O cleanup global exclui qualquer usuário cujo e-mail comece com este prefixo
TEST_USER_PREFIX=qa-rankingpong

# Senha atribuída a todos os usuários de teste criados em runtime
# Use uma senha forte — o banco HML é compartilhado
TEST_USER_PASSWORD=Qa!Rank1ng#2026
