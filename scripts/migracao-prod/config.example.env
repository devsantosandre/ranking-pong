# Config da migração de produção (Cloud -> VPS).
# Copie para config.env e preencha. NÃO commitar (já coberto por .gitignore `.env*`).

# ----- ORIGEM: Supabase Cloud (PROD atual) -----
# Connection string do dashboard: Project Settings > Database > Connection string.
# Use a do "Session pooler" (porta 5432). Inclui a senha do banco.
# Ex.: postgresql://postgres.wylndj...:SENHA@aws-0-sa-east-1.pooler.supabase.com:5432/postgres
SUPABASE_CLOUD_DB_URL="postgresql://postgres.XXXX:SENHA@aws-0-REGIAO.pooler.supabase.com:5432/postgres"

# ----- DESTINO: Postgres self-hosted na VPS (vira PROD) -----
# Connection string do Postgres da VPS. Rode o restore NA VPS apontando para o
# Postgres local (ou via túnel). Ex. local na VPS:
# postgresql://postgres:SENHA@localhost:5432/postgres
VPS_PG_URL="postgresql://postgres:SENHA@localhost:5432/postgres"

# Pasta de saída dos dumps (relativa a este diretório).
DUMP_DIR="./dumps"

# Tabelas de auth a migrar (com hashes de senha). Em geral users + identities bastam.
# Se usar MFA/SSO, acrescente as tabelas correspondentes.
AUTH_TABLES="auth.users auth.identities"

# ----- BACKUP OFF-SITE: Cloudflare R2 (usado por 05-backup-cloud-para-r2.sh) -----
# R2 é S3-compatível. Crie o bucket e um token de API em:
#   Cloudflare Dashboard > R2 > Manage R2 API Tokens (gera Access Key ID + Secret).
# O endpoint usa o seu Account ID.
R2_ENDPOINT="https://<ACCOUNT_ID>.r2.cloudflarestorage.com"
R2_BUCKET="rankingpong-backup-prod"
R2_ACCESS_KEY_ID="<r2_access_key_id>"
R2_SECRET_ACCESS_KEY="<r2_secret_access_key>"
# Prefixo (pasta) dentro do bucket e quantos backups manter (retenção por contagem).
R2_PREFIXO="cloud-prod"
R2_RETENCAO="30"
