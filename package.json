{
  "name": "ranking-pong",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "ratings:audit": "node --env-file=.env.local scripts/repair-rating-history.mjs",
    "ratings:repair": "node --env-file=.env.local scripts/repair-rating-history.mjs --apply",
    "db:push:hml": "supabase link --project-ref \"$SUPABASE_PROJECT_ID_HML\" && supabase db push --dry-run && supabase db push",
    "db:push:prod": "supabase link --project-ref \"$SUPABASE_PROJECT_ID_PROD\" && supabase db push --dry-run && supabase db push",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test && npm run test:e2e",
    "test:seed": "node --env-file=.env.test scripts/seed-test-users.mjs",
    "test:seed:cleanup": "node --env-file=.env.test scripts/seed-test-users.mjs --cleanup"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.87.1",
    "@tanstack/query-sync-storage-persister": "^5.90.23",
    "@tanstack/react-query": "^5.90.12",
    "@tanstack/react-query-persist-client": "^5.90.23",
    "@types/web-push": "^3.6.4",
    "@vercel/speed-insights": "^1.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.556.0",
    "next": "16.0.10",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "tailwind-merge": "^3.4.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.6",
    "baseline-browser-mapping": "^2.9.19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.0.7",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.1.6",
    "ws": "^8.20.1"
  }
}
